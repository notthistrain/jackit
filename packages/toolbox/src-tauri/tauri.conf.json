{
  "productName": "工具箱",
  "version": "0.1.0",
  "identifier": "com.upgrade-component.toolbox",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5170",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "/index.html",
        "title": "工具箱",
        "width": 900,
        "height": 690,
        "center": true,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
